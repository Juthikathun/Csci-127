v=int(input("Enter v"))

if v>= 0 and v<=50:
    print("Good Air Quality")


elif v>=51 and v<=100:
    print("Moderate Air Quality")
elif v>=101 and v<=150:
    print("Unhealthy for Sensitive Groups")
elif v>=151 and v<=200:
    print("Unhealthy Air Quality")
else:
    print("Very Unhealthy Air Quality")


    

    
